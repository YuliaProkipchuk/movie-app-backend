// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  username String
  movies   Movie[]

  @@index([email])
}

model Movie {
  id          String      @id @default(uuid())
  title       String
  description String?
  rating      Int         @default(0)
  image       String?
  genres      Genre[]
  actors      Actor[]
  director    String?
  status      MovieStatus @default(PLANNED)
  releasedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isFavorite  Boolean     @default(false)
  createdBy   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@index([userId])
  @@index([isFavorite])
  @@unique([id, userId])
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  movies    Movie[]
}
model Actor {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  movies    Movie[]
}
enum MovieStatus {
  WATCHED
  PLANNED
}
